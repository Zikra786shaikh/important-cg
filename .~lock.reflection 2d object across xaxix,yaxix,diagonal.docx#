import matplotlib.pyplot as plt
x = [1, 3, 2,1]
y = [1, 1, 3,1]
x_d, y_d = y, x
plt.plot(x , y , 'r', label='Original')
plt.plot(x_d , y_d , 'm', label='Diagonal')
plt.legend()
plt.axis('equal')
plt.title("Reflection Transformation across diagonal Example")
